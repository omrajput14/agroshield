# AgroShield AI — Frontend Environment Variables
# Copy this file to .env.local for local development
# Set these as environment variables in Vercel for production

# Backend API URL
# Local dev (default fallback in api.js, no need to set this):
# VITE_API_BASE_URL=http://localhost:8000/api

# Production (set this in your Vercel project settings):
VITE_API_BASE_URL=https://your-backend.onrender.com/api
